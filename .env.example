# ─── Divider MES — Environment Configuration ──────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and never committed.

# Backend REST API base URL (Headless WordPress / Node on AWS)
# Development: proxy via vite.config.js → http://localhost:3000/wp-json/factory/v1/
# Production:  https://api.yourdomain.com/wp-json/factory/v1/
VITE_API_BASE_URL=/wp-json/factory/v1/

# Admin PIN (overridden at runtime via AdminSettings; stored in localStorage)
# Only used as fallback if localStorage is empty
VITE_DEFAULT_ADMIN_PIN=1234

# Telegram Bot (optional — for Executive Analytics export)
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
